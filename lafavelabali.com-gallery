            window.__SOLE_HOST_INFO__ = { "appId": "pdp-app", "originalHost": "lafavelabali.com", "pageType": "ProductDetailPage", "context": { "brand": "สล็อต888", "locale": "en_TH", "env": "production" }, "initialised": true };
