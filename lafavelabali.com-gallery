        min-width: 0;
        max-width: 310px;
        align-self: center;
    }

    .description_subtitle__5h3_L {
        margin: 0;
        color: #111;
        font-size: 25px;
        line-height: 1.38;
        font-weight: 800;
        letter-spacing: .2px;
        word-break: normal;
    }

    .description_media__QUtul {
        grid-area: image;
        width: 100%;
        max-width: 430px;
    }

    .description_media__QUtul img {
        width: 100%;
        max-width: 430px;
        height: auto;
        display: block;
        object-fit: contain;
    }

    .description_margin__cBW26 {
        grid-area: desc;
        margin: 0;
        color: #222;
        font-size: 16px;
        line-height: 1.85;
        text-align: justify;
        max-width: 100%;
    }

    .ththth-extra-content {
        max-width: 780px;
        margin: 34px auto 0;
        color: #222;
    }

    .ththth-extra-content h3 {
        margin: 28px 0 12px;
        color: #111;
        font-size: 21px;
        line-height: 1.4;
        font-weight: 800;
    }

    .ththth-extra-content p {
        margin: 0 0 16px;
        color: #333;
        font-size: 15.5px;
        line-height: 1.75;
        text-align: justify;
    }

    .ththth-note {
        margin: 22px 0;
        padding: 16px 18px;
        background: #f6f6f6;
        border-left: 4px solid #111;
        color: #333;
        font-size: 15px;
        line-height: 1.75;
    }

    .ththth-info-row {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin: 24px 0;
    }

    .ththth-info-box {
        padding: 16px;
        border: 1px solid #ddd;
        background: #fff;
    }

    .ththth-info-box strong {
        display: block;
        margin-bottom: 7px;
        color: #111;
        font-size: 15px;
    }

    .ththth-info-box span {
        display: block;
        color: #555;
        font-size: 13.5px;
        line-height: 1.6;
    }

    .ththth-faq-clean {
        max-width: 780px;
        margin: 34px auto 0;
        border-top: 1px solid #d7d7d7;
    }

    .ththth-faq-clean details {
        border-bottom: 1px solid #d7d7d7;
    }

    .ththth-faq-clean summary {
        position: relative;
        list-style: none;
        cursor: pointer;
        padding: 22px 46px 22px 0;
        color: #111;
        font-size: 16px;
        font-weight: 800;
    }

    .ththth-faq-clean summary::-webkit-details-marker {
        display: none;
    }

    .ththth-faq-clean summary::after {
        content: "";
        position: absolute;
        right: 8px;
        top: 50%;
        width: 10px;
        height: 10px;
        border-right: 1.8px solid #111;
        border-bottom: 1.8px solid #111;
        transform: translateY(-65%) rotate(45deg);
        transition: .25s ease;
    }

    .ththth-faq-clean details[open] summary::after {
        transform: translateY(-35%) rotate(225deg);
    }

    .ththth-faq-answer {
        padding: 0 0 22px;
        max-width: 780px;
    }

    .ththth-faq-answer p {
        margin: 0;
        color: #444;
        font-size: 15px;
        line-height: 1.75;
        text-align: justify;
    }

